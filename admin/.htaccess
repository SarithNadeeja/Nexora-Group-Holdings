# Serve login flow at /admin/ instead of a directory listing.
DirectoryIndex index.php login.php
Options -Indexes

# Allow larger product photos from phone cameras (mod_php / AllowOverride Options).
<IfModule mod_php.c>
    php_value upload_max_filesize 25M
    php_value post_max_size 28M
    php_value max_file_uploads 20
</IfModule>
